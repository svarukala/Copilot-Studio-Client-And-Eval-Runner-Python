# Copilot Studio Agent Connection Settings
# Copy this to .env and fill in your values

COPILOTSTUDIO_ENVIRONMENT_ID=your-environment-id
COPILOTSTUDIO_SCHEMA_NAME=your-agent-schema-name
COPILOTSTUDIO_TENANT_ID=your-tenant-id
COPILOTSTUDIO_APP_CLIENT_ID=your-app-client-id
COPILOTSTUDIO_APP_CLIENT_SECRET=

# Set to "s2s" for client-credentials flow, "interactive" for browser login
AUTH_MODE=interactive

# Timeout in seconds per SDK call (start_conversation, ask_question). Default: 120
# TIMEOUT_SECONDS=120

# ─────────────────────────────────────────────────────────────────────────────
# LLM-as-a-Judge configuration (optional)
# Required only for these match methods: general_quality, text_similarity, compare_meaning
# ─────────────────────────────────────────────────────────────────────────────

# Provider: "azure_openai", "openai", "openai_compatible", or "ollama"
# JUDGE_PROVIDER=azure_openai

# Endpoint URL
#   Azure:  https://<your-resource>.openai.azure.com/
#   OpenAI: leave blank (uses api.openai.com)
#   Ollama: http://localhost:11434/v1 (default if blank when provider=ollama)
#   LM Studio / vLLM: http://localhost:1234/v1
# JUDGE_BASE_URL=

# API key (set "not-needed" for local endpoints that don't require auth)
# JUDGE_API_KEY=

# Model / deployment name
#   Azure:  the deployment name (e.g., "gpt-4o")
#   OpenAI: model id (e.g., "gpt-4o-mini")
#   Ollama: model tag (e.g., "llama3.1:8b")
# JUDGE_MODEL=

# Azure-only: API version. Default 2024-08-01-preview
# JUDGE_API_VERSION=2024-08-01-preview
